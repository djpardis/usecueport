<footer class="site-footer">
  <div class="container footer-grid">
    <details class="build-panel">
      <summary>v{{ site.version }} · release notes</summary>
      <div class="build-panel-body">
        <ul class="build-list">
          {% for line in site.shipNotes.included %}<li>{{ line | safe }}</li>{% endfor %}
        </ul>
      </div>
    </details>
    <p class="footer-copyright">
      <span class="footer-copyright-full">© {{ "" | year }} {{ site.name }}. All rights reserved.</span>
      <span class="footer-copyright-short">© {{ "" | year }} {{ site.name }}</span>
    </p>
  </div>
</footer>
