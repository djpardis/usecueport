---
layout: layouts/base.njk
title: "Download"
description: "Request a Cueport download link for Mac and iPhone."
permalink: /download/
viewportMain: true
---

<div class="container">
  <div class="page-head">
    <h1>Download</h1>
    <p class="lede">Cueport is rolling out with free access to DJs. Fill the form below and we'll send you a link.</p>
  </div>
  <div class="access-layout">
    <form class="access-form" data-access-form method="POST" action="{{ site.forms.access.action }}">
      <div class="form-grid">
        <label>
          Name
          <input name="full_name" autocomplete="name" required>
        </label>

        <label>
          Email
          <input name="email" type="email" autocomplete="email" required>
        </label>

        <label>
          DJ name
          <input name="DJ_name" autocomplete="organization">
        </label>

        <label>
          Socials or website
          <input name="social_or_site" placeholder="@name or https://...">
        </label>

        <label>
          Main DJ software
          <select name="DJ_software" required>
            <option value="">Choose one</option>
            <option>Serato DJ Pro</option>
            <option>Rekordbox</option>
            <option>Traktor</option>
            <option>VirtualDJ</option>
            <option>Engine DJ</option>
            <option>Other</option>
          </select>
        </label>

        <label>
          Library size
          <select name="library_size">
            <option value="">Choose one</option>
            <option>Under 1,000 tracks</option>
            <option>1,000 to 10,000 tracks</option>
            <option>10,000 to 50,000 tracks</option>
            <option>50,000+ tracks</option>
          </select>
        </label>
      </div>

      <input name="website" tabindex="-1" autocomplete="off" hidden>

      <button class="btn" type="submit">Submit</button>
      <p class="form-status" data-access-form-status role="status" aria-live="polite"></p>
    </form>

    <aside class="access-note">
      <ol class="setup-steps">
        <li>
          <h2>Start on Mac</h2>
          <p>The Mac app links to your <code>_Serato_</code> folder, reads crates, and plays from your local files. It is the source of truth.</p>
        </li>
        <li>
          <h2>Connect your iPhone</h2>
          <p>The iPhone companion pairs to the Mac over your local network to receive crates and tracks.</p>
        </li>
      </ol>
    </aside>
  </div>
</div>

<script>
  const accessForm = document.querySelector("[data-access-form]");
  const accessStatus = document.querySelector("[data-access-form-status]");

  accessForm?.addEventListener("submit", async (event) => {
    event.preventDefault();

    if (!accessForm.reportValidity()) {
      return;
    }

    accessStatus.textContent = "Sending...";

    try {
      const response = await fetch(accessForm.action, {
        method: "POST",
        body: new FormData(accessForm)
      });

      if (response.ok) {
        accessForm.reset();
        accessStatus.textContent = "Thanks. We got your request and we'll get in touch by email.";
        return;
      }

      const body = await response.json().catch(() => ({}));
      accessStatus.textContent = body.error || "Something went wrong. Please try again.";
    } catch {
      accessStatus.textContent = "Could not reach the form service. Please try again.";
    }
  });
</script>
